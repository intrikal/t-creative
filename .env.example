# Copy to .env.local and fill in real values.
# See docs/INTEGRATION_SETUP.md for step-by-step instructions.

# ──────────────────────────────────────────────
# Supabase (Database & Auth)
# https://supabase.com → Project Settings → API
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ──────────────────────────────────────────────
# Database (Drizzle / Postgres)
# ──────────────────────────────────────────────
# Pooled connection — use for queries
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — use for migrations (bypasses pgbouncer)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-us-west-2.pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com

# Random hex strings — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your-random-hex-secret
INVITE_SECRET=your-random-hex-secret
WAIVER_TOKEN_SECRET=your-random-hex-secret

# ──────────────────────────────────────────────
# Square (Payment Processing)
# https://developer.squareup.com/apps
# ──────────────────────────────────────────────
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
NEXT_PUBLIC_SQUARE_APP_ID=your-square-app-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key

# ──────────────────────────────────────────────
# Turnstile (Captcha)
# https://dash.cloudflare.com → Turnstile
# ──────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ──────────────────────────────────────────────
# Resend (Transactional Email)
# https://resend.com/api-keys
# ──────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL="Studio Name <hello@yourdomain.com>"

# ──────────────────────────────────────────────
# Twilio (SMS)
# https://console.twilio.com
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# ──────────────────────────────────────────────
# Zoho (CRM / Books / Campaigns)
# https://api-console.zoho.com → Self Client
# Scopes: ZohoCRM.modules.ALL, ZohoCRM.settings.ALL,
#         ZohoCampaigns.contact.ALL, ZohoBooks.fullaccess.ALL
# ──────────────────────────────────────────────
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_API_DOMAIN=https://www.zohoapis.com
# Zoho Books → Settings → Organization Profile → Organization ID
ZOHO_BOOKS_ORGANIZATION_ID=your-zoho-books-org-id
# Zoho Campaigns → Contact Lists → list → Settings → List Key
ZOHO_CAMPAIGNS_LIST_KEY=your-zoho-campaigns-list-key

# ──────────────────────────────────────────────
# Sentry (Error Tracking)
# https://sentry.io → Project Settings
# ──────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ──────────────────────────────────────────────
# PostHog (Product Analytics)
# https://us.posthog.com → Project Settings
# ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phx_your-posthog-api-key

# ──────────────────────────────────────────────
# S3 Backup Storage
# ──────────────────────────────────────────────
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_ACCESS_KEY_ID=your-s3-access-key-id
BACKUP_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=
BACKUP_S3_KEY_PREFIX=backups/

# ──────────────────────────────────────────────
# Instagram (Feed Sync)
# https://developers.facebook.com/apps → Instagram Basic Display
# Long-lived token (60 days), refreshed automatically by cron
# ──────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your-instagram-long-lived-token

# ──────────────────────────────────────────────
# EasyPost (Shipping)
# https://www.easypost.com/account/api-keys
# ──────────────────────────────────────────────
EASYPOST_API_KEY=your-easypost-api-key
EASYPOST_WEBHOOK_SECRET=your-easypost-webhook-secret

# Studio origin address (used as "from" on shipping labels)
STUDIO_STREET1=123 Main St
STUDIO_STREET2=
STUDIO_CITY=San Jose
STUDIO_STATE=CA
STUDIO_ZIP=95112
STUDIO_PHONE=+14085551234

# ──────────────────────────────────────────────
# Cron Jobs
# Generate with: openssl rand -hex 32
# ──────────────────────────────────────────────
CRON_SECRET=your-random-hex-secret
