# ============================================================
# 🌱 ENVIRONMENT VARIABLES SETUP GUIDE
# ============================================================
# This file shows ALL required environment variables for the app.
#
# ❗ IMPORTANT:
# - NEVER commit your real `.env` file to GitHub
# - This file uses placeholder values only
# - Copy this file → `.env.local` and fill in real values
#
# Command:
#   cp .env.example .env.local
#
# ============================================================



# ============================================================
# 🟦 SUPABASE — Database & Backend
# ============================================================
# Docs: https://supabase.com
#
# Steps:
# 1. Create a project on Supabase
# 2. Go to Project Settings → API
# 3. Copy:
#    - Project URL
#    - anon (public) key
#
# 4. Go to Settings → Database
#    - Copy your database password
#
# ============================================================

SUPABASE_DB_PASSWORD=your_supabase_db_password_here

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key — server-side only, never expose to the browser.
# Required for generating magic links in booking confirmation emails.
# Found at: Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase connection pooler (port 6543, transaction mode)
# Used by the Drizzle runtime client — prevents connection exhaustion
# when 10+ serverless functions run concurrently.
# Found at: Supabase dashboard → Project Settings → Database → Connection pooling
DATABASE_POOLER_URL=postgres://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) — used only by drizzle-kit for migrations.
# DDL statements (CREATE TABLE, ALTER TABLE) must bypass PgBouncer.
# Found at: Supabase dashboard → Project Settings → Database → Connection string
DIRECT_URL=postgres://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# Legacy direct URL — kept for Supabase CLI and pg introspection tooling.
DATABASE_URL=your_database_url_here



# ============================================================
# 🔐 AUTH — Google OAuth
# ============================================================
# Docs: https://console.cloud.google.com
#
# Steps:
# 1. Go to Google Cloud Console
# 2. APIs & Services → Credentials
# 3. Create "OAuth Client ID"
#    - Application type: Web Application
#
# 4. Add redirect URI:
#    http://localhost:3000/api/auth/callback/google
#
# 5. Copy:
#    - Client ID
#    - Client Secret
#
# ============================================================

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here



# ============================================================
# 🔑 APP SECRETS
# ============================================================

# Used to sign invite links / tokens
# Generate with:
#   openssl rand -hex 32
INVITE_SECRET=your_random_invite_secret_here

# Your app URL
# Development:
#   http://localhost:3000
#
# Production example:
#   https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000



# ============================================================
# 🟦 SQUARE — Payments & Bookings
# ============================================================
# Docs: https://developer.squareup.com/apps
#
# Steps:
# 1. Create a Square Developer account
# 2. Open your app → Sandbox tab
# 3. Copy:
#    - Access Token
#    - Location ID
#
# 4. Webhooks → create endpoint → copy signature key
#
# ============================================================

SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key_here



# ============================================================
# 🟨 RESEND — Transactional Emails
# ============================================================
# Docs: https://resend.com
#
# Steps:
# 1. Create account
# 2. API Keys → Create Key
# 3. Verify your domain
#
# ============================================================

RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL="Your App <hello@yourdomain.com>"
# Daily send limit — 100 for free tier, 50000 for Pro plan.
# Emails over the limit are queued and drained the next day.
RESEND_DAILY_LIMIT=100



# ============================================================
# ⏱️ CRON AUTH (Supabase pg_cron)
# ============================================================
# Docs: https://supabase.com/docs/guides/database/extensions/pg_cron
#
# Used to secure scheduled jobs
#
# Generate with:
#   openssl rand -hex 32
#
# ============================================================

CRON_SECRET=your_random_cron_secret_here
# Optional: Discord or Slack incoming webhook URL for cron failure alerts.
# Discord: Server Settings → Integrations → Webhooks → Copy Webhook URL
# Slack:   api.slack.com/messaging/webhooks
CRON_ALERT_WEBHOOK_URL=



# ============================================================
# 📋 LOGGING — Pino
# ============================================================
# Log level: trace | debug | info | warn | error | fatal (default: info)
# In development pino-pretty formats output for readability.
# In production JSON is emitted for log aggregators.
LOG_LEVEL=info



# ============================================================
# 🔴 SENTRY — Error Monitoring & Source Maps
# ============================================================
# Docs: https://sentry.io/settings/account/api/auth-tokens/
#
# Steps:
# 1. Create a Sentry account and project
# 2. Settings → Auth Tokens → Create New Token
#    - Scopes required: project:releases, org:read
# 3. Copy your org slug and project slug from the Sentry dashboard URL
#
# SENTRY_AUTH_TOKEN is used at build time to upload source maps so
# stack traces in Sentry show real file/line numbers (maps are then
# deleted from the bundle so users cannot access your source).
#
# ============================================================

SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_sentry_org_slug_here
SENTRY_PROJECT=your_sentry_project_slug_here



# ============================================================
# 🟪 POSTHOG — Product Analytics
# ============================================================
# Docs: https://posthog.com/docs
#
# Steps:
# 1. Create account
# 2. Project Settings → copy keys
#
# ============================================================

NEXT_PUBLIC_POSTHOG_KEY=your_posthog_public_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://your-posthog-instance
POSTHOG_API_KEY=your_posthog_private_api_key_here



# ============================================================
# 🟩 ZOHO — CRM / Campaigns / Books
# ============================================================
# Docs: https://api-console.zoho.com
#
# Steps:
# 1. Create Self Client
# 2. Copy Client ID + Secret
# 3. Generate refresh token
#
# ============================================================

ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here
ZOHO_API_DOMAIN=https://www.zohoapis.com
ZOHO_CAMPAIGNS_LIST_KEY=your_campaigns_list_key_here
ZOHO_BOOKS_ORGANIZATION_ID=your_organization_id_here



# ============================================================
# 🟧 EASYPOST — Shipping
# ============================================================

EASYPOST_API_KEY=your_easypost_api_key_here
EASYPOST_WEBHOOK_SECRET=your_easypost_webhook_secret_here



# ============================================================
# 🔴 UPSTASH REDIS — Distributed Rate Limiting
# ============================================================
# Docs: https://upstash.com
#
# Steps:
# 1. Create a free Redis database on Upstash
# 2. Go to the database details page
# 3. Copy:
#    - REST URL
#    - REST Token
#
# Used by proxy.ts to enforce sliding-window rate limits on
# public POST endpoints across all serverless instances.
#
# ============================================================

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here



# ============================================================
# 📦 STUDIO ADDRESS
# ============================================================

STUDIO_STREET1=123 Example St
STUDIO_CITY=San Jose
STUDIO_STATE=CA
STUDIO_ZIP=95112
STUDIO_PHONE=+14080000000



# ============================================================
# 📱 TWILIO — SMS Notifications
# ============================================================
# Docs: https://www.twilio.com/docs
#
# Steps:
# 1. Create a Twilio account
# 2. Go to Console → Account Info
# 3. Copy:
#    - Account SID
#    - Auth Token
#
# 4. Buy a phone number → copy it (E.164 format: +1xxxxxxxxxx)
#
# ============================================================

TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+10000000000



# ============================================================
# 🔒 WAIVER TOKEN — Waiver Completion Signing
# ============================================================
# Used to sign and verify waiver completion tokens (HMAC).
#
# Generate with:
#   openssl rand -hex 32
#
# ============================================================

WAIVER_TOKEN_SECRET=your_random_waiver_token_secret_here



# ============================================================
# 📸 INSTAGRAM — Feed Sync (optional)
# ============================================================
# Docs: https://developers.facebook.com/docs/instagram-platform
#
# Steps:
# 1. Create a Facebook App with Instagram Basic Display
# 2. Generate a long-lived access token
#
# Leave blank to skip Instagram feed sync.
#
# ============================================================

INSTAGRAM_ACCESS_TOKEN=



# ============================================================
# 🔔 WEB PUSH — VAPID Keys (optional)
# ============================================================
# Docs: https://web.dev/push-notifications-overview/
#
# Steps:
# 1. Generate a VAPID key pair:
#    npx web-push generate-vapid-keys
#
# 2. Copy the public and private keys below
#
# Leave blank to disable browser push notifications.
#
# ============================================================

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=



# ============================================================
# 🗄️ BACKUP — S3-Compatible Storage (optional)
# ============================================================
# Docs: https://docs.aws.amazon.com/s3/
#
# Steps:
# 1. Create an S3 bucket (or R2/Backblaze B2 bucket)
# 2. Create an IAM user with PutObject/GetObject permissions
# 3. Copy access key ID and secret access key
#
# Leave blank to disable nightly backups.
#
# ============================================================

BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
# Optional: custom endpoint for R2, Backblaze, MinIO, etc.
BACKUP_S3_ENDPOINT=
# Optional: defaults to "auto"
BACKUP_S3_REGION=
# Optional: key prefix inside the bucket (defaults to "backups")
BACKUP_S3_KEY_PREFIX=



# ============================================================
# 🤖 BOT PROTECTION — Google reCAPTCHA v3
# ============================================================
# Docs: https://www.google.com/recaptcha/admin
#
# Steps:
# 1. Register a new site (reCAPTCHA v3)
# 2. Copy the site key and secret key
#
# Required in production for bot protection on public forms.
#
# ============================================================

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here



# ============================================================
# ⚙️ INNGEST — Background Jobs (optional)
# ============================================================
# Docs: https://www.inngest.com/docs
#
# Steps:
# 1. Create an Inngest account
# 2. Go to Settings → Keys
# 3. Copy the Event Key and Signing Key
#
# Required in production for async event processing
# (Square webhooks, background tasks).
#
# ============================================================

INNGEST_EVENT_KEY=your_inngest_event_key_here
INNGEST_SIGNING_KEY=your_inngest_signing_key_here



# ============================================================
# 📧 ADMIN EMAIL (optional)
# ============================================================
# Email address for system notifications (e.g., error alerts,
# new corporate inquiries).
#
# ============================================================

ADMIN_EMAIL=



# ============================================================
# ✅ DONE
# ============================================================
# 1. Save as `.env.local`
# 2. Run:
#    npm run dev
#
# ============================================================