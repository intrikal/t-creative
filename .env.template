# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
SUPABASE_DB_PASSWORD=your-supabase-db-password

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Prisma / Drizzle — Supabase Shared Connection Pooler
# Use this for query connections (pgbouncer=true for Prisma)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used for migrations (bypasses pgbouncer)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-us-west-2.pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Random hex string — used to sign invite tokens
INVITE_SECRET=your-random-hex-secret

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Square — payments and bookings
# https://developer.squareup.com/apps
# ──────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ──────────────────────────────────────────────
# Resend — transactional email
# https://resend.com/api-keys
# ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="Studio Name <hello@yourdomain.com>"

# ──────────────────────────────────────────────
# Cron — authenticates pg_cron scheduled job requests
# Generate with: openssl rand -hex 32
# ──────────────────────────────────────────────
CRON_SECRET=your-random-hex-secret

# ──────────────────────────────────────────────
# PostHog — product analytics
# https://us.posthog.com → Project Settings
# ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# ──────────────────────────────────────────────
# Zoho CRM / Campaigns / Books
# https://api-console.zoho.com → Self Client
# Scopes: ZohoCRM.modules.ALL, ZohoCRM.settings.ALL,
#         ZohoCampaigns.contact.ALL, ZohoBooks.fullaccess.ALL
# ──────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_DOMAIN=https://www.zohoapis.com

# Zoho Campaigns — Contact Lists → list → Settings → List Key
ZOHO_CAMPAIGNS_LIST_KEY=

# Zoho Books — Settings → Organization Profile → Organization ID
ZOHO_BOOKS_ORGANIZATION_ID=

# ──────────────────────────────────────────────
# EasyPost — shipping labels and tracking
# https://www.easypost.com/account/api-keys
# ──────────────────────────────────────────────
EASYPOST_API_KEY=
EASYPOST_WEBHOOK_SECRET=

# Studio origin address (used as "from" on shipping labels)
STUDIO_STREET1=
STUDIO_CITY=
STUDIO_STATE=
STUDIO_ZIP=
STUDIO_PHONE=
